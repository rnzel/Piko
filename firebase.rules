rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === USERS COLLECTION ===
    match /users/{userId} {
      // Only the user can read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can create their own document on sign-up
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId;

      // Private tasks — only the owning user
      match /private_tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Prevent changing ownership
        allow create: if request.resource.data.createdBy == request.auth.uid;

        // Prevent deleting createdAt (immutable)
        allow update: if request.resource.data.createdAt == resource.data.createdAt;
      }

      // Notifications — only the owning user
      match /notifications/{noteId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
                       && request.resource.data.keys().hasAll(['read', 'readAt']);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Denormalized memberships — only the owning user
      match /memberships/{groupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // === USERS LIST (for search/invite) ===
    // Authenticated users can list and search users for group invitations
    match /users/{document=**} {
      allow list: if request.auth != null;
    }

    // === GROUPS COLLECTION (GLOBAL) ===
    match /groups/{groupId} {
      // Members can always read full group documents.
      allow read: if request.auth != null
                  && exists(
                    /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                  );

      // P0.2 join-by-code support:
      // Authenticated users may read non-archived group docs to resolve invite code joins.
      // (Further hardening can move this to a dedicated public index/lookup document later.)
      allow read: if request.auth != null
                  && resource.data.isArchived != true;

      // Authenticated users can create groups
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.memberCount == 1;

      // Only owner and admins can update group metadata
      allow update: if request.auth != null
                    && (
                      get(
                        /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                      ).data.role in ['owner', 'admin']
                    );

      // Only owner can delete a group
      allow delete: if request.auth != null
                    && get(
                      /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                    ).data.role == 'owner';

      // === GROUP MEMBERS ===
      match /members/{memberId} {
        // Members can read members list
        allow read: if request.auth != null
                    && exists(
                      /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                    );

        // A user can create their own membership (join by code)
        allow create: if request.auth != null
                      && request.auth.uid == memberId
                      && request.resource.data.role == 'member'
                      && request.resource.data.uid == request.auth.uid;

        // Owner/admins can add other members
        allow create: if request.auth != null
                      && get(
                        /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                      ).data.role in ['owner', 'admin'];

        // Users can update their own membership (e.g., leave, toggle notifications)
        allow update: if request.auth != null && request.auth.uid == memberId;

        // Users can delete their own membership (leave group)
        allow delete: if request.auth != null && request.auth.uid == memberId;

        // Owner can remove any member
        allow delete: if request.auth != null
                      && get(
                        /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                      ).data.role == 'owner';
      }

      // === GROUP TASKS ===
      match /tasks/{taskId} {
        // All members can read group tasks
        allow read: if request.auth != null
                    && exists(
                      /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                    );

        // Members can create tasks
        allow create: if request.auth != null
                      && exists(
                        /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                      )
                      && request.resource.data.createdBy == request.auth.uid;

        // Members can update tasks (but cannot change createdBy or id)
        allow update: if request.auth != null
                      && exists(
                        /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                      )
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.id == resource.data.id;

        // Only creator, owner, or admin can delete a group task
        allow delete: if request.auth != null
                      && (
                        resource.data.createdBy == request.auth.uid ||
                        get(
                          /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                        ).data.role in ['owner', 'admin']
                      );
      }

      // === GROUP ACTIVITY ===
      match /activity/{activityId} {
        // Members can read activity
        allow read: if request.auth != null
                    && exists(
                      /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                    );

        // Activity is append-only by members
        allow create: if request.auth != null
                      && exists(
                        /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)
                      )
                      && request.resource.data.actorUid == request.auth.uid;

        // Activity is never updated or deleted
        allow update, delete: if false;
      }
    }

    // === INVITATIONS ===
    match /invitations/{invitationId} {
      // The invited user can read their own pending invites
      allow read: if request.auth != null
                  && (
                    resource.data.invitedUid == request.auth.uid ||
                    resource.data.invitedEmail ==
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
                  );

      // Creator can read invites they sent
      allow read: if request.auth != null
                  && resource.data.invitedByUid == request.auth.uid;

      // Authenticated users can create invitations
      allow create: if request.auth != null
                    && request.resource.data.invitedByUid == request.auth.uid;

      // Only the invited user can update status (accept/decline)
      allow update: if request.auth != null
                    && (
                      request.resource.data.invitedUid == request.auth.uid ||
                      resource.data.invitedEmail ==
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
                    )
                    && request.resource.data.status in ['accepted', 'declined'];

      // Creator can delete (cancel) their own invites
      allow delete: if request.auth != null
                    && resource.data.invitedByUid == request.auth.uid;
    }

    // === META COLLECTION (for group code uniqueness) ===
    match /_meta/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}