rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === USERS COLLECTION ===
    match /users/{userId} {
      // Only the user can read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can create their own document on sign-up
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId;

      // Private tasks — only the owning user
      match /private_tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Prevent changing ownership
        allow create: if request.resource.data.createdBy == request.auth.uid;

        // Prevent deleting createdAt (immutable)
        allow update: if request.resource.data.createdAt == resource.data.createdAt;
      }

      // Notifications — only the owning user
      match /notifications/{noteId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
                       && request.resource.data.keys().hasAll(['read', 'readAt']);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Denormalized memberships (inert — no longer written to)
      match /memberships/{groupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // === META COLLECTION ===
    match /_meta/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}